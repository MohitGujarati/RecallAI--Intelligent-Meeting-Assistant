<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ── Audio recording ─────────────────────────────────────── -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- ── Foreground service (microphone type declared explicitly) ─ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <!-- ── Notifications ───────────────────────────────────────── -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ── Network (Whisper/Gemini API calls) ──────────────────── -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- ── Phone state (pause on incoming call) ────────────────── -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- ── Bluetooth audio source detection ────────────────────── -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- ── WorkManager reliable scheduling ─────────────────────── -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".RecallApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RecallAI">

        <!-- ── Main entry point ──────────────────────────────────── -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.RecallAI">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ── Recording foreground service ──────────────────────── -->
        <!--
            foregroundServiceType="microphone" is mandatory on API 30+
            for services that access the microphone while in background.
            android:exported="false" — only this app can start it.
        -->
        <service
            android:name=".service.RecordingService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>